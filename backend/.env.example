# Backend environment configuration — copy to .env and fill in real values

# Postgres (provisioned by deploy/values-postgresql.yaml)
DATABASE_URL=postgresql://postgres:CHANGE_ME@lebarre-group-postgresql.colossus-apps.svc.cluster.local:5432/lebarre_group_db

# Redis (currently unused at runtime; reserved for future cache/queue work)
REDIS_URL=redis://:CHANGE_ME@lebarre-group-redis-master.colossus-apps.svc.cluster.local:6379

# JWT signing secret for admin sessions
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=12h

# SMTP — admin notification email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="LeBarre Group <noreply@lebarregroup.com>"
ADMIN_NOTIFICATION_EMAIL=admin@lebarregroup.com

# Public site origin — used to build absolute URLs in sitemap.xml and robots.txt
PUBLIC_SITE_ORIGIN=https://lebarregroup.com

# Allowed CORS origin(s), comma-separated
CORS_ORIGINS=https://lebarregroup.com

# Server
PORT=3000
NODE_ENV=production
